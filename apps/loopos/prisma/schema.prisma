  L0
  L1
  L2
  L3
  L4
}

enum AiExecutionAuditEventStatus {
  RECORDED
  DENIED
}

enum CardStatus {
  UNSIGNED // 未签
  SIGNED // 已签
  STRESS_TESTED // 已压力测试
}

enum TensionType {
  PROBLEMATIC // 问题性（某事卡住）
  CONSTRUCTIVE // 建设性（有更好做法）
  CLARIFYING // 澄清性（角色边界不清）
}

enum TensionSource {
