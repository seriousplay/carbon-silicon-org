  ASSIGNED // 已指派负责人
  IN_PROGRESS // 处理中
  BLOCKED // 被外部依赖阻塞
  ESCALATED_L0_5 // 紧急升级（生产故障）
  ESCALATED_L2 // 回路间接口升级
  ESCALATED_L3 // 治理流程/决策者升级
  ESCALATED_L4 // 战略级升级
  RESOLVED // 已闭环
  REJECTED // 不成立/重复
}

