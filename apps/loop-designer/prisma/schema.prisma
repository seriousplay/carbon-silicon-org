// Prisma schema for Loop Designer (Carbon-Silicon Loop Designer)
// Migrated from Supabase project B (zfuojnosurshknvcnkgi)
// Only loop_designer_* and loop_os_* tables included

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core User ────────────────────────────────────────

model LoopDesignerUser {
  id            String    @id @default(uuid()) @db.Uuid
  tenantKey     String    @map("tenant_key")
  openId        String    @map("open_id")
  unionId       String?   @map("union_id")
  feishuUserId  String?   @map("feishu_user_id")
  displayName   String    @map("display_name")
  avatarUrl     String?   @map("avatar_url")
  email         String?   @unique
  passwordHash  String?   @map("password_hash")
  authProvider  String    @default("feishu") @map("auth_provider")
  phoneHash     String?   @map("phone_hash")
  status        String    @default("active")
  enterpriseId  String?   @map("enterprise_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  lastLoginAt   DateTime  @default(now()) @map("last_login_at") @db.Timestamptz()

  enterprise          LoopDesignerEnterprise?       @relation(fields: [enterpriseId], references: [id])
  authSessions        LoopDesignerAuthSession[]
  sessions            LoopDesignerSession[]
  enterpriseMembers   LoopDesignerEnterpriseMember[]
  createdInvites      LoopDesignerInviteCode[]      @relation("InviteCreator")
  generationJobs      LoopDesignerGenerationJob[]
  loopAssets          LoopOsAsset[]                 @relation("AssetCreator")
  loopVersions        LoopOsVersion[]               @relation("VersionCreator")
  loopRelationships   LoopOsRelationship[]          @relation("RelationshipCreator")
  evolutionEvents     LoopOsEvolutionEvent[]        @relation("EventCreator")
  interfaceProtocols  LoopOsInterfaceProtocol[]     @relation("ProtocolCreator")
  auditLogs           LoopDesignerAuditLog[]

  @@unique([tenantKey, openId])
  @@index([enterpriseId])
  @@index([email])
  @@index([phoneHash])
  @@map("loop_designer_users")
}

// ─── Auth ─────────────────────────────────────────────

model LoopDesignerAuthSession {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz()
  lastSeenAt DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz()
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz()
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user       LoopDesignerUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("loop_designer_auth_sessions")
}

// ─── Enterprise ───────────────────────────────────────

model LoopDesignerEnterprise {
  id               String    @id @default(uuid()) @db.Uuid
  tenantKey        String    @unique @map("tenant_key")
  companyName      String    @map("company_name")
  subscriptionTier String    @default("free") @map("subscription_tier")
  seatLimit        Int       @default(5) @map("seat_limit")
  usedSeats        Int       @default(0) @map("used_seats")
  featureFlags     Json      @default("{}") @map("feature_flags")
  billingContact   Json?     @map("billing_contact")
  isActive         Boolean   @default(true) @map("is_active")
  isTrial          Boolean   @default(false) @map("is_trial")
  trialEndsAt      DateTime? @map("trial_ends_at") @db.Timestamptz()
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  users            LoopDesignerUser[]
  members          LoopDesignerEnterpriseMember[]
  settings         LoopDesignerEnterpriseSetting?
  auditLogs        LoopDesignerAuditLog[]
  inviteCodes      LoopDesignerInviteCode[]
  sessions         LoopDesignerSession[]
  generationJobs   LoopDesignerGenerationJob[]
  loopAssets       LoopOsAsset[]
  loopRelationships LoopOsRelationship[]
  evolutionEvents  LoopOsEvolutionEvent[]
  interfaceProtocols LoopOsInterfaceProtocol[]
  orgProfile       LoopOsOrgProfile?

  @@map("loop_designer_enterprises")
}

model LoopDesignerEnterpriseMember {
  id           String    @id @default(uuid()) @db.Uuid
  enterpriseId String    @map("enterprise_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  role         String    @default("member")
  invitedBy    String?   @map("invited_by") @db.Uuid
  isActive     Boolean   @default(true) @map("is_active")
  joinedAt     DateTime  @default(now()) @map("joined_at") @db.Timestamptz()
  leftAt       DateTime? @map("left_at") @db.Timestamptz()

  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user         LoopDesignerUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, userId])
  @@index([enterpriseId])
  @@index([userId])
  @@map("loop_designer_enterprise_members")
}

model LoopDesignerEnterpriseSetting {
  id                        String   @id @default(uuid()) @db.Uuid
  enterpriseId              String   @unique @map("enterprise_id") @db.Uuid
  defaultAiModel            String   @default("step-router-v1") @map("default_ai_model")
  enableAiClaude            Boolean  @default(false) @map("enable_ai_claude")
  enableCustomKnowledgeBase Boolean  @default(false) @map("enable_custom_knowledge_base")
  branding                  Json     @default("{}")
  dataRetentionDays         Int      @default(365) @map("data_retention_days")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                 DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  enterprise                LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@map("loop_designer_enterprise_settings")
}

model LoopDesignerAuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  enterpriseId String    @map("enterprise_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  action       String
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id") @db.Uuid
  details      Json      @default("{}")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user         LoopDesignerUser?      @relation(fields: [userId], references: [id])

  @@index([enterpriseId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("loop_designer_audit_logs")
}

model LoopDesignerInviteCode {
  id           String    @id @default(uuid()) @db.Uuid
  enterpriseId String    @map("enterprise_id") @db.Uuid
  code         String    @unique
  createdBy    String    @map("created_by") @db.Uuid
  maxUses      Int       @default(0) @map("max_uses")
  usedCount    Int       @default(0) @map("used_count")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz()
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  creator      LoopDesignerUser       @relation("InviteCreator", fields: [createdBy], references: [id])

  @@index([enterpriseId, isActive])
  @@index([code])
  @@map("loop_designer_invite_codes")
}

// ─── Sessions ─────────────────────────────────────────

model LoopDesignerSession {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  enterpriseId        String?   @map("enterprise_id") @db.Uuid
  status              String    @default("in_progress")
  participantSnapshot Json      @default("{}") @map("participant_snapshot")
  context             Json      @default("{\"currentStep\": 0}")
  responses           Json      @default("{}")
  outputs             Json      @default("{\"messages\": [], \"versions\": [], \"refinementCount\": 0}")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  submittedAt         DateTime? @map("submitted_at") @db.Timestamptz()

  user                LoopDesignerUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  enterprise          LoopDesignerEnterprise? @relation(fields: [enterpriseId], references: [id])
  generationJobs      LoopDesignerGenerationJob[]
  loopAssets          LoopOsAsset[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([enterpriseId])
  @@map("loop_designer_sessions")
}

model LoopDesignerGenerationJob {
  id           String    @id @default(uuid()) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  enterpriseId String    @map("enterprise_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  status       String    @default("queued")
  useOrgMemory Boolean   @default(true) @map("use_org_memory")
  attempts     Int       @default(0)
  maxAttempts  Int       @default(2) @map("max_attempts")
  lockedAt     DateTime? @map("locked_at") @db.Timestamptz()
  lockedBy     String?   @map("locked_by")
  lastError    String?   @map("last_error")
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  startedAt    DateTime? @map("started_at") @db.Timestamptz()
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz()

  session      LoopDesignerSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  user         LoopDesignerUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enterpriseId, status, createdAt])
  @@index([enterpriseId, sessionId, createdAt(sort: Desc)])
  @@index([status, lockedAt])
  @@map("loop_designer_generation_jobs")
}

// ─── Loop OS ──────────────────────────────────────────

model LoopOsAsset {
  id                   String    @id @default(uuid()) @db.Uuid
  enterpriseId         String    @map("enterprise_id") @db.Uuid
  title                String
  domain               String    @default("未分类")
  status               String    @default("incubating")
  currentVersionId     String?   @map("current_version_id") @db.Uuid
  sourceSessionId      String?   @map("source_session_id") @db.Uuid
  matrixWorkspaceId    String?   @map("matrix_workspace_id")
  matrixCircuitLogicalId String? @map("matrix_circuit_logical_id")
  matrixBaseVersionId  String?   @map("matrix_base_version_id")
  createdBy            String    @map("created_by") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  enterprise           LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  sourceSession        LoopDesignerSession?   @relation(fields: [sourceSessionId], references: [id])
  creator              LoopDesignerUser       @relation("AssetCreator", fields: [createdBy], references: [id])
  versions             LoopOsVersion[]
  sourceRelationships  LoopOsRelationship[]   @relation("SourceAsset")
  targetRelationships  LoopOsRelationship[]   @relation("TargetAsset")
  evolutionEvents      LoopOsEvolutionEvent[]

  @@index([enterpriseId, updatedAt(sort: Desc)])
  @@index([enterpriseId, matrixWorkspaceId, matrixCircuitLogicalId])
  @@map("loop_os_assets")
}

model LoopOsVersion {
  id                    String   @id @default(uuid()) @db.Uuid
  assetId               String   @map("asset_id") @db.Uuid
  versionNumber         Int      @map("version_number")
  plan                  Json
  maturityMapping       Json?    @map("maturity_mapping")
  birthCertificate      Json?    @map("birth_certificate")
  sourceSessionVersionId String? @map("source_session_version_id")
  changeReason          String?  @map("change_reason")
  createdBy             String   @map("created_by") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()

  asset                 LoopOsAsset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  creator               LoopDesignerUser @relation("VersionCreator", fields: [createdBy], references: [id])
  evolutionEvents       LoopOsEvolutionEvent[]

  @@unique([assetId, versionNumber])
  @@map("loop_os_versions")
}

model LoopOsRelationship {
  id             String   @id @default(uuid()) @db.Uuid
  enterpriseId   String   @map("enterprise_id") @db.Uuid
  sourceAssetId  String   @map("source_asset_id") @db.Uuid
  targetAssetId  String   @map("target_asset_id") @db.Uuid
  type           String
  direction      String   @default("source_to_target")
  interfaceName  String?  @map("interface_name")
  strength       String   @default("important")
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  enterprise     LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  sourceAsset    LoopOsAsset           @relation("SourceAsset", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  targetAsset    LoopOsAsset           @relation("TargetAsset", fields: [targetAssetId], references: [id], onDelete: Cascade)
  creator        LoopDesignerUser      @relation("RelationshipCreator", fields: [createdBy], references: [id])
  protocols      LoopOsInterfaceProtocol[]

  @@index([enterpriseId, createdAt(sort: Desc)])
  @@index([enterpriseId, sourceAssetId])
  @@index([enterpriseId, targetAssetId])
  @@map("loop_os_relationships")
}

model LoopOsEvolutionEvent {
  id           String   @id @default(uuid()) @db.Uuid
  enterpriseId String   @map("enterprise_id") @db.Uuid
  assetId      String   @map("asset_id") @db.Uuid
  versionId    String?  @map("version_id") @db.Uuid
  eventType    String   @map("event_type")
  runSequence  Int?     @map("run_sequence")
  runMode      String?  @map("run_mode")
  payload      Json
  createdBy    String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  asset        LoopOsAsset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  version      LoopOsVersion?        @relation(fields: [versionId], references: [id])
  creator      LoopDesignerUser      @relation("EventCreator", fields: [createdBy], references: [id])

  @@index([enterpriseId, assetId, createdAt(sort: Desc)])
  @@index([enterpriseId, assetId, runSequence])
  @@map("loop_os_evolution_events")
}

model LoopOsInterfaceProtocol {
  id                 String   @id @default(uuid()) @db.Uuid
  enterpriseId       String   @map("enterprise_id") @db.Uuid
  relationshipId     String   @map("relationship_id") @db.Uuid
  versionNumber      Int      @map("version_number")
  couplingType       String   @map("coupling_type")
  semanticProtocol   Json     @map("semantic_protocol")
  structuralProtocol Json     @map("structural_protocol")
  governanceProtocol Json     @map("governance_protocol")
  status             String   @default("draft")
  changeReason       String?  @map("change_reason")
  createdBy          String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  enterprise         LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  relationship       LoopOsRelationship     @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  creator            LoopDesignerUser       @relation("ProtocolCreator", fields: [createdBy], references: [id])

  @@unique([relationshipId, versionNumber])
  @@index([enterpriseId, createdAt(sort: Desc)])
  @@index([enterpriseId, relationshipId, versionNumber(sort: Desc)])
  @@map("loop_os_interface_protocols")
}

model LoopOsOrgProfile {
  enterpriseId String   @id @db.Uuid
  profile      Json
  source       String   @default("loop_os_v1")
  computedAt   DateTime @default(now()) @map("computed_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  enterprise   LoopDesignerEnterprise @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@map("loop_os_org_profiles")
}
