# 环境变量配置模板
# 复制此文件为 .env.local 并填写真实值

# ==================== 应用配置 ====================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://zfuojnosurshknvcnkgi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Use the same Matrix Origin Supabase project. SUPABASE_SECRET_KEY is accepted
# for compatibility with apps/matrix-origin.
SUPABASE_SECRET_KEY=your-matrix-origin-service-role-key-here
SUPABASE_SERVICE_ROLE_KEY=your-matrix-origin-service-role-key-here

# ==================== LLM 配置 ====================
# 6.24 默认：DeepSeek V4 Pro 主用，Step 3.7 Flash 备用。
MODEL_FALLBACK_ORDER=deepseek,step
MODEL_TIMEOUT_MS=300000
MODEL_PROBE_TIMEOUT_MS=10000
# 生产环境默认不静默使用本地 fallback；本地开发如需演示可设为 true。
MODEL_FALLBACK_ENABLED=false

# 方案生成采用持久任务队列：Web 进程只提交任务，worker 进程领取任务并调用模型。
LOOP_GENERATION_WORKER_SECRET=replace-with-worker-secret
LOOP_GENERATION_WORKER_URL=http://127.0.0.1:3010/loop-designer/api/generation-jobs/run
LOOP_GENERATION_WORKER_INTERVAL_MS=5000
LOOP_GENERATION_WORKER_LIMIT=1
LOOP_GENERATION_STALE_MS=900000
LOOP_GENERATION_MAX_ATTEMPTS=2

DEEPSEEK_MODEL_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL_NAME=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high

STEP_MODEL_API_URL=https://api.stepfun.com/step_plan/v1/chat/completions
STEP_MODEL_API_KEY=your-step-api-key-here
STEP_MODEL_NAME=step-3.7-flash
STEP_REASONING_EFFORT=medium

# 旧版单模型配置仍兼容，建议只作为最后 fallback 使用。
# MODEL_API_URL=https://api.stepfun.com/step_plan/v1/chat/completions
# MODEL_API_KEY=your-model-api-key-here
# MODEL_NAME=step-router-v1

# ==================== 飞书集成 ====================
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-feishu-secret-here
FEISHU_ALLOWED_TENANT_KEY=your-tenant-key-here
FEISHU_ALLOWED_TENANT_KEYS=
FEISHU_TENANT_ACCESS_MODE=allowlist
FEISHU_OPEN_ACCESS_UNTIL=2026-06-24T23:59:59+08:00
FEISHU_EXPORT_FOLDER_TOKEN=your-folder-token-here

# Event quick login for closed-door course users.
# Login identity is phone number.
LOOP_EVENT_LOGIN_ENABLED=false
LOOP_EVENT_ACCESS_UNTIL=2026-06-24T23:59:59+08:00

# One-time legacy data copy from the old Loop Designer Supabase project.
LOOP_SOURCE_SUPABASE_URL=https://old-loop-project.supabase.co
LOOP_SOURCE_SERVICE_ROLE_KEY=old-loop-service-role-key
MATRIX_SUPABASE_URL=https://zfuojnosurshknvcnkgi.supabase.co
MATRIX_SUPABASE_SERVICE_ROLE_KEY=your-matrix-origin-service-role-key-here

# ==================== 平台租户管理 ====================
# 平台管理员需要同时满足：命中以下任一白名单 + 在自己企业内是 super_admin。
LOOP_PLATFORM_ADMIN_TENANT_KEYS=
LOOP_PLATFORM_ADMIN_UNION_IDS=
LOOP_PLATFORM_ADMIN_OPEN_IDS=

# ==================== 认证会话 ====================
# 生成方法: openssl rand -hex 32
LOOP_AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
LOOP_AUTH_SESSION_TTL_SECONDS=1209600

# ==================== PDF 生成 ====================
CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
# Matrix Origin integration
MATRIX_ORIGIN_ED25519_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
MATRIX_LOOP_CALLBACK_SECRET=
MATRIX_ORIGIN_INTERNAL_URL=http://localhost:3020
