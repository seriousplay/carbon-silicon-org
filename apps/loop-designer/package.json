{
  "name": "@carbon-silicon/loop-designer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build && node scripts/prepare-standalone.mjs",
    "start": "next start --port 3010",
    "worker:generation": "node scripts/generation-worker.mjs",
    "lint": "eslint",
    "test": "tsx --test src/lib/*.test.ts",
    "clean": "rm -rf .next .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "templates:generate": "node scripts/generate-industry-loop-templates.mjs"
  },
  "dependencies": {
    "@carbon-silicon/db": "workspace:*",
    "@carbon-silicon/types": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "puppeteer-core": "^24.31.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
