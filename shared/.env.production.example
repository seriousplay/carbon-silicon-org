# ─── Shared Environment Variables ───
# This file is sourced by all apps on the production server.
# Location: /var/www/carbon-silicon-org/shared/.env

# PostgreSQL (unified instance)
DATABASE_URL=postgresql://csi_admin:CHANGE_ME@localhost:5432

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
AUTH_SECRET=generate_with_openssl_rand_-hex_32

# Email (SMTP for magic link)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=noreply@csi-org.com
EMAIL_SERVER_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@csi-org.com

# LLM / AI Model (shared across loop-designer and loopos)
MODEL_API_URL=https://api.deepseek.com/v1
MODEL_API_KEY=CHANGE_ME
MODEL_NAME=deepseek-chat
MODEL_TIMEOUT_MS=300000
